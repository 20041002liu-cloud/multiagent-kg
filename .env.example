MODEL_BASE_URL=
MODEL_API_KEY=EMPTY
MODEL_NAME=openpangu-1b
MODEL_TEMPERATURE=0.1
MODEL_TIMEOUT_SECONDS=90
MODEL_AUTOSTART=true
MODEL_START_SCRIPT=
MODEL_START_TIMEOUT_SECONDS=180
MODEL_COMBINED_EXTRACTION=false
EXTRACTION_CACHE_ENABLED=true
EXTRACTION_CONCURRENCY=1

NEO4J_URI=
NEO4J_USER=neo4j
NEO4J_PASSWORD=neo4j

APP_HOST=127.0.0.1
APP_PORT=8090

CHUNK_SIZE=900
CHUNK_OVERLAP=80
# 0 means run all chunks. Set this for large OCR documents to avoid very long agent runs.
RUN_CHUNK_LIMIT=0

# OCR fallback for scanned/image-only PDFs. Requires Tesseract OCR installed locally.
PDF_OCR_ENABLED=true
PDF_OCR_LANGUAGE=chi_sim+eng
PDF_OCR_DPI=180
# 0 means OCR all pages. Set this while testing very large PDFs.
PDF_OCR_MAX_PAGES=0
PDF_OCR_TIMEOUT_SECONDS=120
PDF_OCR_CONCURRENCY=1
PDF_OCR_MIN_CHARS_PER_PAGE=80
TESSERACT_CMD=
