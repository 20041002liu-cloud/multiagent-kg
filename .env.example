# 复制此文件为 .env 并修改实际值
# Copy this file to .env and fill in your actual values
MODEL_BASE_URL=http://127.0.0.1:8088/v1
EMBEDDING_BASE_URL=http://127.0.0.1:8089/v1
EMBEDDING_MODEL_NAME=BAAI/bge-m3
EMBEDDING_DIM=1024
MODEL_API_KEY=EMPTY
MODEL_NAME=openpangu-embedded-7b
MODEL_TEMPERATURE=0.1
MODEL_TIMEOUT_SECONDS=90
MODEL_MAX_TOKENS=1024
MODEL_AUTOSTART=true
MODEL_START_SCRIPT=D:\your_path\start_openpangu_7b.ps1
MODEL_START_TIMEOUT_SECONDS=180
MODEL_COMBINED_EXTRACTION=false
EXTRACTION_CACHE_ENABLED=true
EXTRACTION_CONCURRENCY=2

NEO4J_URI=bolt://127.0.0.1:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_password_here

APP_HOST=127.0.0.1
APP_PORT=8090

CHUNK_SIZE=900
CHUNK_OVERLAP=80
RUN_CHUNK_LIMIT=0

PDF_OCR_ENABLED=true
PDF_OCR_LANGUAGE=chi_sim+eng
PDF_OCR_DPI=180
PDF_OCR_MAX_PAGES=0
PDF_OCR_TIMEOUT_SECONDS=120
PDF_OCR_CONCURRENCY=2
PDF_OCR_MIN_CHARS_PER_PAGE=80
TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe  # 按实际路径修改
